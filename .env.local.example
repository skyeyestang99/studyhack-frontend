# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_ENV=local

# Run the UI standalone with built-in mock data (no backend required).
# Set to false when running against the real backend on NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_USE_MOCKS=true

# Optional mock scenarios: default, empty-courses, loading, error.
NEXT_PUBLIC_MOCK_SCENARIO=default
# Optional delay applied to mock API responses. "loading" defaults to 1500ms.
# NEXT_PUBLIC_MOCK_DELAY_MS=1500

# Future variables
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
